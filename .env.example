# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DATABASE_URL=jdbc:postgresql://localhost:5432/notion_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your-secure-password-here

# ==========================================
# JWT CONFIGURATION
# ==========================================
# CRITICAL: Generate a strong secret key (minimum 32 characters)
# Example: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-must-be-at-least-32-chars-long
JWT_EXPIRATION_HOURS=2

# ==========================================
# CORS CONFIGURATION
# ==========================================
# Comma-separated list of allowed origins for CORS
# Example for multiple origins: http://localhost:4200,https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ==========================================
# JPA/HIBERNATE CONFIGURATION
# ==========================================
# Valid values: validate, update, create, create-drop
# Production recommended: validate
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false
